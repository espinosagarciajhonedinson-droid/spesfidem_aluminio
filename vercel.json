{
  "installCommand": "echo 'Install handled by build script'",
  "buildCommand": "chmod +x build_vercel.sh && sh build_vercel.sh",
  "outputDirectory": "vercel_dist",
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/consultoria",
      "destination": "/consultoria/index.html"
    },
    {
      "source": "/consultoria/(.*)",
      "destination": "/consultoria/index.html"
    }
  ],
  "headers": [
    {
      "source": "/consultoria/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
