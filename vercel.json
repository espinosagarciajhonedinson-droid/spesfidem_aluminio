{
  "installCommand": "echo 'Install handled by build script'",
  "buildCommand": "chmod +x build_vercel.sh && sh build_vercel.sh",
  "outputDirectory": "vercel_dist",
  "routes": [
    {
      "src": "^/consultoria/assets/(.*)",
      "dest": "/consultoria/assets/$1",
      "headers": {
        "Cache-Control": "public, max-age=604800, immutable"
      }
    },
    {
      "src": "^/consultoria/(.*)",
      "dest": "/consultoria/index.html"
    },
    {
      "src": "^/consultoria$",
      "dest": "/consultoria/index.html"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/(.*)",
      "dest": "/$1"
    }
  ]
}
